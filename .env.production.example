# Production on bot-me.neeklo.ru — copy to /var/www/bot-me.neeklo.ru/.env

POSTGRES_USER=botme
POSTGRES_PASSWORD=CHANGE_ME_STRONG
POSTGRES_DB=botme

DATABASE_URL=postgresql://botme:CHANGE_ME_STRONG@postgres:5432/botme?schema=public
REDIS_URL=redis://redis:6379

API_PORT=3001
JWT_SECRET=CHANGE_ME_LONG_RANDOM
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS

WEB_ORIGIN=https://bot-me.neeklo.ru
NEXT_PUBLIC_API_URL=https://bot-me.neeklo.ru

SEED_ADMIN_EMAIL=dsc-23@yandex.ru
SEED_ADMIN_PASSWORD=CHANGE_ME
SEED_ADMIN_NAME=Джон Уик

# Optional: pre-seed Neeklo API key (also editable in /admin/settings)
NEEKLO_API_KEY=

# SMTP (email notifications to org admins)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=botme <noreply@bot-me.neeklo.ru>
SMTP_SECURE=false

# E2E test activation (prod only — set in GitHub Actions secrets too)
E2E_TEST_SECRET=
